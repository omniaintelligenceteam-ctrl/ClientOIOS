{
  "framework": "nextjs",
  "buildCommand": "next build",
  "outputDirectory": ".next",
  "crons": [
    {
      "path": "/api/cron/morning-briefing",
      "schedule": "30 10,11,12,13 * * *"
    },
    {
      "path": "/api/cron/automation-scheduler",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/drip-sender",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/metrics-snapshot",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/client-health-check",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/process-client-crons",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/admin/demo/reset",
      "schedule": "0 8 * * *"
    }
  ]
}
